# ================================================================
# GESTIÓ RAMADERA BOVINA — Variables d'Entorn
# ================================================================
# Copia aquest fitxer com .env.local i omple els valors reals.
# IMPORTANT: Mai pujar .env.local a Git.
# Les variables de producció es configuren a Vercel Dashboard.
# ================================================================

# Base de dades — Supabase connection string (Transaction Pooler port 6543)
# Obtenir a: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=""

# JWT — Clau secreta per signar els tokens
# Generar amb: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=""

# Durada dels tokens (format: 1h, 30d, 15m...)
JWT_ACCESS_EXPIRY="1h"
JWT_REFRESH_EXPIRY="30d"

# URL de l'aplicació
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron Jobs — Secret per protegir els endpoints de tasques programades
# Generar amb: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# A Vercel, aquest valor s'injecta automàticament a les capçaleres del Cron
# si es configura com a variable d'entorn amb el mateix nom.
CRON_SECRET=""
